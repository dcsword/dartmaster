{
  "appId": "com.dartscorer501.app",
  "appName": "501 Dart Scorer",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "ios": {
    "contentInset": "automatic"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#1a1a2e"
    },
    "StatusBar": {
      "style": "DARK"
    }
  }
}